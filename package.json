{
  "name": "siyuan-plugin-task-manager",
  "version": "11.0.0",
  "type": "module",
  "description": "Task Manager is a plugin for Siyuan Notes, designed to centrally manage tasks scattered throughout your entire workspace. It helps you easily track and manage to-do items by adding rich metadata to each task, multiplying your work efficiency.",
